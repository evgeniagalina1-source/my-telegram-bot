# Токен вашего Telegram-бота (получите его у @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Ключ API для доступа к GigaChat
GIGACHAT_API_KEY=your_gigachat_api_key

# ID Google-таблицы (если используется)
GOOGLE_SHEET_ID=your_google_sheet_id

# Путь к файлу учетных данных Google (если используется)
GOOGLE_CREDENTIALS_FILE=credentials.json